<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0F172A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GraviSAT GPU/NPU Shield"
        android:textColor="#F8FAFC"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnRunAudit"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Launch Parallel Hardware Pass"
        android:backgroundTint="#10B981"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvTelemetryOutput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="System Idling. Awaiting Bare-Metal Vector Grid Activation..."
        android:textColor="#38BDF8"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:padding="16dp"
        android:background="#1E293B"/>

</LinearLayout>
